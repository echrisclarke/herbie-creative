# Reviewers: use YOUR keys. Do not commit real secrets.
OPENAI_API_KEY=

# Image path: auto (Responses tool first, Images fallback) | responses | images
OPENAI_IMAGE_API=auto
# Mainline model that hosts the image_generation tool (not gpt-image-*)
# gpt-5.6: original/auto keep input dimensions; gpt-5.4 auto follows high resize
OPENAI_RESPONSES_MODEL=gpt-5.6
# Vision detail for input images on Responses: original | high | low | auto
OPENAI_IMAGE_INPUT_DETAIL=original
# GPT Image model (Images/Vision SOTA). Use "auto" on Responses to omit pin.
OPENAI_IMAGE_MODEL=gpt-image-2
# medium ~5x cheaper than high on gpt-image-2; use high for finals
OPENAI_IMAGE_QUALITY=medium
# jpeg is faster than png; png forced automatically when masks need alpha
OPENAI_IMAGE_OUTPUT_FORMAT=jpeg
OPENAI_IMAGE_OUTPUT_COMPRESSION=85
# Supported on gpt-image-1 / 1.5; omitted automatically for gpt-image-2
OPENAI_IMAGE_INPUT_FIDELITY=high

# Google Fonts Developer API (searchable family catalog in Review picker)
GOOGLE_FONTS_API_KEY=

# Optional motion / Grok Imagine path (post-creative Image-to-Video)
XAI_API_KEY=
MOTION_ENABLED=false
MOTION_DURATION_SECONDS=6
MOTION_VIDEO_MODEL=grok-imagine-video-1.5
MOTION_VIDEO_RESOLUTION=720p

# Adobe Firefly (planned; untested in this POC — no author license)
# See docs/references/README.md and docs/references/firefly-api.json
ADOBE_FIREFLY_CLIENT_ID=
ADOBE_FIREFLY_CLIENT_SECRET=
ADOBE_FIREFLY_ACCESS_TOKEN=
ADOBE_FIREFLY_API_KEY=

# Local storage only for this proof of concept
STORAGE_BACKEND=local

# --- Hosted / Railway (optional) ---
# HOSTED=1 enables login, per-user API keys, and per-user campaign folders.
# HOSTED=1
# DATA_ROOT=/data
# CAMPAIGNS_ROOT=/data/campaigns
# SECRET_KEY=generate-a-long-random-string
# ENCRYPTION_KEY=generate-another-long-random-string
# BOOTSTRAP_ADMIN_EMAIL=you@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me-now
# Host OPENAI_API_KEY / XAI_API_KEY power a short free trial, then users must add their own.
# TRIAL_RUNS_LIMIT=3
